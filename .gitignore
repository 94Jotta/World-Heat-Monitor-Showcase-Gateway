# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, you may want to ignore it.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different OS, they may break the lock.
# .env

# poetry
#   According to poetry documentation, the lock file should be committed to version control.
# .poetry.lock

# pdm
#   According to pdm documentation, the lock file should be committed to version control.
# .pdm-python.path
# .pdm-build/

# PEP 582; used by e.g. github.com/pdm-project/pdm
__pypackages__/

